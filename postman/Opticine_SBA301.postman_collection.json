{
  "info": {
    "name": "Opticine SBA301 API Collection",
    "description": "Bo suu tap API dung cho nop bai SBA301. Collection su dung bien {{baseUrl}}, {{adminToken}}, {{customerToken}}, {{staffToken}} va khong chua token hoac secret that.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "adminToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "staffToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Dang nhap, dang ky va dat lai mat khau.",
      "item": [
        {
          "name": "Login Admin - success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 - dang nhap admin thanh cong', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Co token', () => pm.expect(body.token || body.accessToken || body.jwt).to.exist);",
            "pm.collectionVariables.set('adminToken', body.token || body.accessToken || body.jwt);",
            "pm.test('Khong lo mat khau', () => pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('password'));"
          ] } }]
        },
        {
          "name": "Login Customer - success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 - dang nhap khach hang thanh cong', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('customerToken', body.token || body.accessToken || body.jwt);",
            "pm.test('Co token', () => pm.expect(pm.collectionVariables.get('customerToken')).to.exist);",
            "pm.test('Khong lo mat khau', () => pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('password'));"
          ] } }]
        },
        {
          "name": "Login Staff - success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200 - dang nhap nhan vien thanh cong', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('staffToken', body.token || body.accessToken || body.jwt);",
            "pm.test('Co token', () => pm.expect(pm.collectionVariables.get('staffToken')).to.exist);",
            "pm.test('Khong lo mat khau', () => pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('password'));"
          ] } }]
        },
        {
          "name": "Login - wrong password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"{{customerEmail}}\",\n  \"password\": \"wrong-password\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Sai mat khau bi tu choi', () => pm.expect(pm.response.code).to.be.oneOf([400, 401, 403]));",
            "pm.test('Khong lo mat khau', () => pm.expect(pm.response.text().toLowerCase()).to.not.include('password'))"
          ] } }]
        },
        {
          "name": "Register Customer - success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Khach hang Postman\",\n  \"email\": \"postman.customer+{{$timestamp}}@opticine.local\",\n  \"phone\": \"09{{$timestamp}}\",\n  \"password\": \"Demo123456\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Dang ky thanh cong', () => pm.response.to.have.status(200));",
            "pm.test('Response JSON ton tai', () => pm.expect(pm.response.json()).to.be.an('object'));",
            "pm.test('Khong lo mat khau', () => pm.expect(pm.response.text().toLowerCase()).to.not.include('password'))"
          ] } }]
        },
        {
          "name": "Register - invalid email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Invalid Email\",\n  \"email\": \"not-an-email\",\n  \"phone\": \"0900000001\",\n  \"password\": \"Demo123456\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Email khong hop le bi tu choi', () => pm.expect(pm.response.code).to.be.oneOf([400, 422]));"
          ] } }]
        },
        {
          "name": "Forgot Password - request reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{customerEmail}}\"\n}" },
            "url": "{{baseUrl}}/auth/forgot-password"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Yeu cau reset tra ve 200 de khong tiet lo email', () => pm.response.to.have.status(200));",
            "pm.test('Response JSON ton tai', () => pm.expect(pm.response.json()).to.be.an('object'));"
          ] } }]
        },
        {
          "name": "Reset Password - invalid token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"invalid-token\",\n  \"newPassword\": \"Demo123456\"\n}" },
            "url": "{{baseUrl}}/auth/reset-password"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Token sai bi tu choi', () => pm.expect(pm.response.code).to.be.oneOf([400, 404, 422]));"
          ] } }]
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        { "name": "Get public movies", "request": { "method": "GET", "url": "{{baseUrl}}/movies" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('JSON exists', () => pm.expect(pm.response.json()).to.exist);"] } }] },
        { "name": "Get hot movies", "request": { "method": "GET", "url": "{{baseUrl}}/movies/hot" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('JSON exists', () => pm.expect(pm.response.json()).to.exist);"] } }] },
        { "name": "Admin create movie", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Postman Movie {{$timestamp}}\",\n  \"description\": \"Phim demo cho SBA301\",\n  \"genre\": \"Drama\",\n  \"durationMinutes\": 105,\n  \"releaseDate\": \"2026-07-21\",\n  \"endDate\": \"2026-12-31\",\n  \"ageRating\": \"P\",\n  \"status\": \"ACTIVE\",\n  \"posterUrl\": \"https://example.com/poster.jpg\",\n  \"trailerUrl\": \"https://example.com/trailer\"\n}" }, "url": "{{baseUrl}}/admin/movies" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));", "const body = pm.response.json();", "pm.test('movie id exists', () => pm.expect(body.id).to.exist);", "pm.environment.set('movieId', body.id);", "pm.test('Khong lo mat khau', () => pm.expect(pm.response.text().toLowerCase()).to.not.include('password'));"] } }] },
        { "name": "Admin update movie", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Postman Movie Updated\",\n  \"description\": \"Cap nhat phim demo\",\n  \"genre\": \"Action\",\n  \"durationMinutes\": 110,\n  \"releaseDate\": \"2026-07-21\",\n  \"endDate\": \"2026-12-31\",\n  \"ageRating\": \"P\",\n  \"status\": \"ACTIVE\"\n}" }, "url": "{{baseUrl}}/admin/movies/{{movieId}}" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"] } }] },
        { "name": "Admin delete movie", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/admin/movies/{{movieId}}" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Delete accepted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204, 409]));"] } }] },
        { "name": "Search/filter movies", "request": { "method": "GET", "url": "{{baseUrl}}/movies?keyword=demo&status=ACTIVE" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }] }
      ]
    },
    {
      "name": "Rooms",
      "item": [
        { "name": "Admin get rooms", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/admin/rooms" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('JSON exists', () => pm.expect(pm.response.json()).to.exist);"] } }] },
        { "name": "Admin create room", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Room {{$timestamp}}\",\n  \"totalRows\": 5,\n  \"totalColumns\": 8,\n  \"screenType\": \"2D\",\n  \"priceMultiplier\": 1.0,\n  \"status\": \"ACTIVE\"\n}" }, "url": "{{baseUrl}}/admin/rooms" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));", "const body = pm.response.json(); pm.environment.set('roomId', body.id);", "pm.test('room id exists', () => pm.expect(body.id).to.exist);"] } }] },
        { "name": "Admin update room", "request": { "method": "PUT", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Room Updated\",\n  \"totalRows\": 5,\n  \"totalColumns\": 8,\n  \"screenType\": \"IMAX\",\n  \"priceMultiplier\": 1.2,\n  \"status\": \"ACTIVE\"\n}" }, "url": "{{baseUrl}}/admin/rooms/{{roomId}}" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"] } }] },
        { "name": "Admin delete room", "request": { "method": "DELETE", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }], "url": "{{baseUrl}}/admin/rooms/{{roomId}}" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Delete accepted', () => pm.expect(pm.response.code).to.be.oneOf([200, 204, 409]));"] } }] },
        { "name": "Create room should verify seats are generated if backend supports it", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"rowCount\": 5,\n  \"columnCount\": 8\n}" }, "url": "{{baseUrl}}/admin/rooms/{{roomId}}/generate-seats" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Seats generated or validation returned', () => pm.expect(pm.response.code).to.be.oneOf([200, 201, 400, 409]));", "pm.test('JSON exists when success', () => { if (pm.response.code < 300) pm.expect(pm.response.json()).to.exist; });"] } }] }
      ]
    },
    {
      "name": "Seats",
      "item": [
