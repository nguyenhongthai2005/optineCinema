      ]
    },
    {
      "name": "Showtimes",
      "item": [
        { "name": "Get public showtimes", "request": { "method": "GET", "url": "{{baseUrl}}/showtimes?date=2026-07-21" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('JSON exists', () => pm.expect(pm.response.json()).to.exist);"] } }] },
        { "name": "Admin create showtime", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"movieId\": {{movieId}},\n  \"roomId\": {{roomId}},\n  \"startTime\": \"2026-08-01T10:00:00\",\n  \"endTime\": \"2026-08-01T12:00:00\",\n  \"status\": \"SCHEDULED\"\n}" }, "url": "{{baseUrl}}/admin/showtimes" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));", "const body = pm.response.json(); pm.environment.set('showtimeId', body.id);", "pm.test('showtime id exists', () => pm.expect(body.id).to.exist);"] } }] },
        { "name": "Create showtime - overlap should fail", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"movieId\": {{movieId}},\n  \"roomId\": {{roomId}},\n  \"startTime\": \"2026-08-01T10:30:00\",\n  \"endTime\": \"2026-08-01T12:30:00\",\n  \"status\": \"SCHEDULED\"\n}" }, "url": "{{baseUrl}}/admin/showtimes" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Overlap rejected', () => pm.expect(pm.response.code).to.be.oneOf([400, 409, 422]));"] } }] },
