        { "name": "Update seat type", "request": { "method": "PATCH", "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"seatType\": \"VIP\"\n}" }, "url": "{{baseUrl}}/admin/seats/1/type" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('Seat type updated or id invalid', () => pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]));"] } }] },
