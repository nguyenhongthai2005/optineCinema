{
  "info": {
    "name": "Optine Cinema (Edge Cases & Features)",
    "description": "Bộ API test toàn bộ luồng Auth, Giữ chỗ, Thanh toán và Hủy vé dành cho bài thuyết trình đồ án.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Đăng ký tài khoản (Happy Path / Trùng lặp)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test_demo@gmail.com\",\n  \"password\": \"12345678\",\n  \"fullName\": \"Khách Hàng Demo\",\n  \"phone\": \"0901234567\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "1.2 Đăng ký lỗi (Validate Mật khẩu yếu / Thiếu trường)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong_email\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "1.3 Đăng nhập (Lấy Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test_demo@gmail.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Booking & Concurrency",
      "item": [
        {
          "name": "2.1 Giữ ghế (Lock Seats - Giữ 2 phút)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seatIds\": [1, 2]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/showtimes/{{showtimeId}}/lock-seats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "showtimes", "{{showtimeId}}", "lock-seats"]
            }
          }
        },
        {
          "name": "2.2 Tạo Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.bookingId) {",
                  "    pm.collectionVariables.set(\"bookingId\", jsonData.bookingId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"showtimeId\": {{showtimeId}},\n  \"seatIds\": [1, 2],\n  \"paymentMethod\": \"VNPAY\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings"]
            }
          }
        },
        {
          "name": "2.3 Lấy danh sách Lịch sử đặt vé (My Bookings)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/my-bookings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "my-bookings"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Payment Exceptions (Edge Cases)",
      "item": [
        {
          "name": "3.1 Hủy đơn hàng (User Hủy)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{bookingId}}", "cancel"]
            }
          }
        },
        {
          "name": "3.2 Thanh toán lại (Retry Payment - Tự động re-lock)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/retry-payment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bookings", "{{bookingId}}", "retry-payment"]
            }
          }
        }
      ]
    },
    {
      "name": "4. E-Ticket & Staff",
      "item": [
        {
          "name": "4.1 Staff Verify Ticket (Quét mã QR)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{staffToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/staff/verify-ticket?qrCode=YOUR_UUID_QR_CODE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "staff", "verify-ticket"],
              "query": [
                { "key": "qrCode", "value": "YOUR_UUID_QR_CODE" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "staffToken",
      "value": ""
    },
    {
      "key": "showtimeId",
      "value": "1"
    },
    {
      "key": "bookingId",
      "value": "1"
    }
  ]
}
